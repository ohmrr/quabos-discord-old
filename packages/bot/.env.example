NODE_ENV="production"    # Required, must either "development" or "production" for slash command deployment.
DATABASE_URL=""          # Required, MongoDB Atlas connection string.
DISCORD_TOKEN=""         # Required, from Discord Developer Portal.
DEV_DISCORD_TOKEN=""     # Optional, secondary token for development. If not provided for development, will default to primary token.
DEV_GUILD_ID=""          # Optional, only necessary if NODE_ENV="development". Needed to deploy slash commands to a dev Discord server.
TZ="America/Los_Angeles" # Optional, IANA Time Zone, will default to "America/Los_Angeles".
